# Runtime
NODE_ENV=development
PORT=4000

# Databases
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/beelearnt
NEON_AUTH_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/neondb
NEON_FETCH_TIMEOUT_MS=30000
NEON_USER_SYNC_ENABLED=true
NEON_USER_SYNC_INTERVAL_MS=60000
NEON_USER_SYNC_BATCH_SIZE=100

# Better Auth / Neon Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000/api/auth
NEON_AUTH_BASE_URL=http://localhost:3000/api/auth

# Social providers
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
FACEBOOK_CLIENT_ID=replace-with-facebook-client-id
FACEBOOK_CLIENT_SECRET=replace-with-facebook-client-secret

# Backend JWT
JWT_SECRET=replace-with-a-long-random-secret

# OpenAI
OPENAI_API_KEY=

# App / CORS
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Daily access code
DAILY_ACCESS_CODE_SECRET=replace-with-a-long-random-secret

# News integration
NEWS_API_KEY=

# Resend (for 2FA + notifications — https://resend.com)
RESEND_API_KEY=re_replace-with-your-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Novu (SMS OTP + login alerts - https://novu.co)
NOVU_API_KEY=
NOVU_API_BASE_URL=https://api.novu.co
NOVU_WORKFLOW_ID_OTP=
NOVU_WORKFLOW_ID_LOGIN_ALERT=

# Auth rollout flags
AUTH_ENFORCE_EMAIL_VERIFICATION=false
AUTH_ENABLE_LOGIN_ALERTS=true

ADMIN_EMAIL=admin@beelearnt.com
FROM_EMAIL=noreply@yourdomain.com
